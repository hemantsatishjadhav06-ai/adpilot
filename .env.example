# ── AdPilot environment (Phase 0→1 MVP) ───────────────────────────────────
# The MVP runs with ZERO of these set — defaults are safe (dry-run, no LLM).

# Server
PORT=8787

# Runtime DB location (SQLite). Defaults to your OS temp dir.
# ADPILOT_DB=/absolute/path/to/adpilot.db

# Safety: writes are DRY-RUN by default. Set to 0 ONLY behind a real connector.
ADPILOT_DRY_RUN=1

# Optional: let Claude refine optimizer rationales (decisions stay deterministic).
# Requires BOTH of these. Without them the system uses its built-in logic.
ADPILOT_USE_LLM=0
# ANTHROPIC_API_KEY=sk-ant-...

# ── Production-only (not used by the MVP; documented for the graduation path) ──
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# META_APP_ID=
# META_APP_SECRET=
# META_SYSTEM_USER_TOKEN=        # encrypt at rest (Vault/KMS) — spends real money
# GOOGLE_ADS_DEVELOPER_TOKEN=
# INNGEST_EVENT_KEY=
# LANGFUSE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
